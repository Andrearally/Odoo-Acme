<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="inherit_atachemnt_form_view" model="ir.ui.view">
        <field name="name">inherit.attachment.form.view</field>
        <field name="model">ir.attachment</field>
        <field name="inherit_id" ref="base.view_attachment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='mimetype']" position="after">
                <field name="is_compressed" string="Is Compressed?"/>

            </xpath>
        </field>
    </record>

     <record id="inherit_atachemnt_tree_view" model="ir.ui.view">
        <field name="name">inherit.attachment.tree.view</field>
        <field name="model">ir.attachment</field>
        <field name="inherit_id" ref="base.view_attachment_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="is_compressed" string="Is Compressed?"/>

            </xpath>
        </field>
    </record>
</odoo>
