# Copy to .env.mcp and fill in. .env.mcp is gitignored — never commit real keys.
# Source it before launching Claude Code:  set -a; source .env.mcp; set +a
#
# Connector: https://github.com/tuanle96/mcp-odoo  (install: `uvx odoo-mcp --health` or `pipx install odoo-mcp`)
# Odoo version: 19. Transport: "xmlrpc" works on 16-19 and is the simplest; switch to "json2"
#   only if you want the Odoo 19 External JSON-2 API (then set ODOO_*_API_KEY and ODOO_*_JSON2_DATABASE_HEADER=1).
# API keys: generate one per branch for the `mcp-bot` user (developer mode → user → API Keys).

# ---- PRODUCTION (master: https://www.acme-racing.com/) ----  writes ENABLED, but Claude confirms every write; mcp-bot is restricted in Odoo
ODOO_PROD_URL=https://www.acme-racing.com
ODOO_PROD_DB=acme-racing
ODOO_PROD_USERNAME=mcp-bot
ODOO_PROD_API_KEY=
ODOO_PROD_TRANSPORT=xmlrpc
ODOO_PROD_ENABLE_WRITES=1

# (No dedicated staging branch — master + dev only.)

# ---- DEVELOPMENT (Odoo.SH dev branch build) ----
ODOO_DEV_URL=https://acmeracing-19-0-31791711.dev.odoo.com
ODOO_DEV_DB=acmeracing-19-0-31791711
ODOO_DEV_USERNAME=mcp-bot
ODOO_DEV_API_KEY=
ODOO_DEV_TRANSPORT=xmlrpc
