# Copy to .env.mcp and fill in. .env.mcp is gitignored — never commit real keys.
# Source it before launching Claude Code:  set -a; source .env.mcp; set +a
#
# Connector: https://github.com/tuanle96/mcp-odoo  (install: `uvx odoo-mcp --health` or `pipx install odoo-mcp`)
# Transport: use "xmlrpc" for Odoo 16-19; use "json2" only on Odoo 19 (then set ODOO_*_API_KEY and add ODOO_JSON2_DATABASE_HEADER=1).

# ---- PRODUCTION (master) ----  writes ENABLED, but Claude confirms every write; mcp-bot is restricted in Odoo
ODOO_PROD_URL=https://acme.odoo.com
ODOO_PROD_DB=acme-master-prod
ODOO_PROD_USERNAME=mcp-bot
ODOO_PROD_API_KEY=
ODOO_PROD_TRANSPORT=xmlrpc
ODOO_PROD_ENABLE_WRITES=1

# ---- STAGING ----
ODOO_STAGING_URL=https://acme-staging-XXXX.dev.odoo.com
ODOO_STAGING_DB=acme-staging-XXXX
ODOO_STAGING_USERNAME=mcp-bot
ODOO_STAGING_API_KEY=
ODOO_STAGING_TRANSPORT=xmlrpc

# ---- DEVELOPMENT ----
ODOO_DEV_URL=https://acme-dev-XXXX.dev.odoo.com
ODOO_DEV_DB=acme-dev-XXXX
ODOO_DEV_USERNAME=mcp-bot
ODOO_DEV_API_KEY=
ODOO_DEV_TRANSPORT=xmlrpc
